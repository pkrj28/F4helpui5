<core:FragmentDefinition xmlns:valuehelpdialog="sap.ui.comp.valuehelpdialog"
	xmlns:core="sap.ui.core"
	xmlns="sap.m">

	<Dialog title="Select any one entry" contentWidth="40%">
		<content>
			<Table id="idtable" items="{/Travel}" >
				<columns>
					<Column>
						<Text text="Travel Id"></Text>
					</Column>
					<Column>
						<Text text="Agency ID"></Text>
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Active" press="onrow">
						<cells>
							<Text  text="{TravelId}"/>
							<Text text="{AgencyId}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</content>
		<endButton>
			<Button text="Close" type="Reject" press="Onclose"></Button>
		</endButton>
	</Dialog>
</core:FragmentDefinition>